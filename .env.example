# ============================================
# AI Marketing Compliance Engine - Environment
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# --- Azure Computer Vision (Image Analysis 4.0) ---
AZURE_VISION_ENDPOINT=https://your-vision-resource.cognitiveservices.azure.com/
AZURE_VISION_KEY=your-vision-key-here

# --- Azure OpenAI (GPT-4.1) ---
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Azure Blob Storage ---
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=compliance-uploads

# --- PostgreSQL ---
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Redis (Upstash) ---
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-redis-token-here

# --- CORS (comma-separated origins, empty = allow all in dev) ---
CORS_ALLOWED_ORIGINS=

# --- Rules file path (relative to project root) ---
RULES_FILE_PATH=backend/data/rules.json
